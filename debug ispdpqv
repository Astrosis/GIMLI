WITH CTE AS (SELECT  
  DISTINCT GA_SESSION_ID,
  YETI.EVENT_DATE, 
  FIRST_VALUE(GEO.COUNTRY IGNORE NULLS) OVER (PARTITION BY GA_SESSION_ID ORDER BY EVENT_TIMESTAMP ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) COUNTRY,
  FIRST_VALUE(GEO.CITY IGNORE NULLS) OVER (PARTITION BY GA_SESSION_ID ORDER BY EVENT_TIMESTAMP ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) CITY, 
  USER_PSEUDO_ID,
  FIRST_VALUE(TRAFFICSOURCE.IGNORE_REFERRER IGNORE NULLS
    ) OVER (
      PARTITION BY GA_SESSION_ID 
      ORDER BY EVENT_TIMESTAMP 
      ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING
  ) SESSION_IGNORE_REFERRER,
  FIRST_VALUE(CASE WHEN TRAFFICSOURCE.GCLID IS NOT NULL THEN 'google_ads' END IGNORE NULLS
    ) OVER (
      PARTITION BY GA_SESSION_ID 
      ORDER BY EVENT_TIMESTAMP 
      ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING
  ) SESSION_GOOGLE_ADS,
  FIRST_VALUE(SESSION_SOURCE IGNORE NULLS
    ) OVER (
      PARTITION BY GA_SESSION_ID 
      ORDER BY EVENT_TIMESTAMP 
      ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING
  ) SESSION_SOURCE_FIRST,
  FIRST_VALUE(SESSION_MEDIUM IGNORE NULLS
   ) OVER (
    PARTITION BY GA_SESSION_ID 
    ORDER BY EVENT_TIMESTAMP 
    ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING
  ) SESSION_MEDIUM_FIRST,
  LOWER (FIRST_VALUE(CASE WHEN TRAFFICSOURCE.SOURCE IS NULL AND TRAFFICSOURCE.MEDIUM IS NOT NULL THEN 'unidentified' ELSE TRAFFICSOURCE.SOURCE END IGNORE NULLS
    ) OVER (
      PARTITION BY GA_SESSION_ID 
      ORDER BY EVENT_TIMESTAMP 
      ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING
  )) TRAFFIC_SOURCE_FIRST,
  LOWER (FIRST_VALUE(CASE WHEN TRAFFICSOURCE.SOURCE IS NOT NULL AND TRAFFICSOURCE.MEDIUM IS NULL THEN 'unidentified' ELSE TRAFFICSOURCE.MEDIUM END IGNORE NULLS
    ) OVER (
      PARTITION BY GA_SESSION_ID 
      ORDER BY EVENT_TIMESTAMP 
      ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING
  )) TRAFFIC_MEDIUM_FIRST,
  FIRST_VALUE(DEVICE.OPERATING_SYSTEM IGNORE NULLS) OVER (PARTITION BY GA_SESSION_ID ORDER BY EVENT_TIMESTAMP ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) OPERATING_SYSTEM,
  FIRST_VALUE(DEVICE.WEB_INFO.BROWSER_VERSION IGNORE NULLS) OVER (PARTITION BY GA_SESSION_ID ORDER BY EVENT_TIMESTAMP ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) BROWSER_VERSION,
  FIRST_VALUE(PAGE.PAGE_PATH IGNORE NULLS) OVER (PARTITION BY GA_SESSION_ID ORDER BY EVENT_TIMESTAMP ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) LANDING_PAGE, 
  FIRST_VALUE(ISYETI2 IGNORE NULLS) OVER (PARTITION BY GA_SESSION_ID ORDER BY EVENT_TIMESTAMP ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) ISYETI2, 
  1 AS ISSESSION,
  CASE
    WHEN PAGE.PAGE_PATH LIKE '%/products/%' AND REGEXP_EXTRACT(LOWER(PAGE.PAGE_PATH), r'ab[0-9]{1,6}')IS NOT NULL THEN 1
    ELSE 0
    END ISPDP,--v2
  FIRST_VALUE(CASE
    WHEN (PAGE.PAGE_PATH LIKE '%/products/%' 
        AND REGEXP_CONTAINS(LOWER(PAGE.PAGE_PATH), r'ab[0-9]{1,6}')) 
      OR (EVENT_NAME = 'open_drawer' 
        AND DRAWER_SUBTYPE ='Product') THEN 1 ELSE 0
    END IGNORE NULLS) OVER (PARTITION BY GA_SESSION_ID ORDER BY YETI.EVENT_DATE ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) ISPDPQV,
  FIRST_VALUE(
    CASE
      WHEN (EVENT_NAME = "search_executed" AND SEARCH_NUMBER_OF_RESULTS != 0) THEN 1 END 
      IGNORE NULLS) OVER (
        PARTITION BY GA_SESSION_ID 
        ORDER BY EVENT_TIMESTAMP 
        ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) ISSEARCHWITHRESULTS,
  FIRST_VALUE(
    CASE
      WHEN (EVENT_NAME = "search_executed" AND SEARCH_NUMBER_OF_RESULTS = 0) THEN 1 END 
      IGNORE NULLS) OVER (
        PARTITION BY GA_SESSION_ID 
        ORDER BY EVENT_TIMESTAMP 
        ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) ISSEARCHZERORESULTS,
  FIRST_VALUE(
    CASE
      WHEN (EVENT_NAME = "search_executed" AND SEARCH_NUMBER_OF_RESULTS != 0) THEN EVENT_TIMESTAMP END 
      IGNORE NULLS) OVER (
        PARTITION BY GA_SESSION_ID 
        ORDER BY EVENT_TIMESTAMP 
        ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) FIRSTTIMESTAMP_ISSEARCHWITHRESULTS,
  FIRST_VALUE(
    CASE
      WHEN (EVENT_NAME = "search_executed" AND SEARCH_NUMBER_OF_RESULTS = 0) THEN EVENT_TIMESTAMP END 
      IGNORE NULLS) OVER (
        PARTITION BY GA_SESSION_ID 
        ORDER BY EVENT_TIMESTAMP 
        ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) FIRSTTIMESTAMP_ISSEARCHZERORESULTS,
  FIRST_VALUE(
    CASE
      WHEN (PAGE.PAGE_PATH LIKE '%/products/%' AND REGEXP_CONTAINS(LOWER(PAGE.PAGE_PATH), r'ab[0-9]{1,6}')) OR (EVENT_NAME = 'open_drawer' AND DRAWER_SUBTYPE ='Product') THEN EVENT_TIMESTAMP END 
      IGNORE NULLS) OVER (
        PARTITION BY GA_SESSION_ID 
        ORDER BY EVENT_TIMESTAMP 
        ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) FIRSTTIMESTAMP_ISPDPQV,
  CASE 
    WHEN GEO.COUNTRY IN ('Austria','Belgium','Bulgaria','Croatia','Cyprus','Czechia','Denmark','Estonia','Finland','France','Germany',
        'Greece','Hungary','Ireland','Italy','Latvia','Lithuania','Luxembourg','Malta','Netherlands','Poland','Portugal','Romania',
        'Slovakia','Slovenia','Spain','Sweden','United Kingdom') 
    THEN "GDPR Country" 
    END as GDPRCountry,
  (LAST_VALUE(EVENT_TIMESTAMP IGNORE NULLS) OVER (PARTITION BY GA_SESSION_ID ORDER BY YETI.EVENT_DATE ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING)
   - FIRST_VALUE(EVENT_TIMESTAMP IGNORE NULLS) OVER (PARTITION BY GA_SESSION_ID ORDER BY YETI.EVENT_DATE ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING))/1000000 SESSION_DURATION,
  CASE
    WHEN FIRST_VALUE(YETI.EVENT_DATE IGNORE NULLS) OVER (PARTITION BY GA_SESSION_ID ORDER BY YETI.EVENT_DATE ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) >
    FIRST_VALUE(YETI.EVENT_DATE IGNORE NULLS) OVER (PARTITION BY USER_PSEUDO_ID ORDER BY YETI.EVENT_DATE ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) THEN 0
    ELSE 1
  END ISNEWVISITOR,
  CASE
    WHEN SUM (CASE WHEN EVENT_NAME = 'page_view' THEN 1 ELSE 0 END) OVER (PARTITION BY GA_SESSION_ID ORDER BY YETI.EVENT_DATE ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) > 1 THEN 0
    ELSE 1
  END AS ISBOUNCESESSION,
 CASE
    WHEN ((EVENT_NAME = 'punchout_session_started' OR EVENT_NAME='punchout_session_started_in_browse' ) IS NULL OR SESSION_SOURCE NOT IN ('connect.punchout2go.com','connect.tradecentric.com')) AND EVENT_NAME = 'web_engagement' AND CLICK_ID = 'Add to basket' THEN 1 ELSE 0 END ISBASKET,
  CASE
    WHEN 
      (FIRST_VALUE (
        CASE WHEN PAGE.PAGE_PATH LIKE '%checkout%' THEN EVENT_TIMESTAMP END IGNORE NULLS
        ) OVER (
          PARTITION BY GA_SESSION_ID 
          ORDER BY EVENT_TIMESTAMP 
          ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) <
      FIRST_VALUE (
        CASE WHEN PAGE.PAGE_PATH LIKE '%confirmation%' THEN EVENT_TIMESTAMP END IGNORE NULLS
        ) OVER (
          PARTITION BY GA_SESSION_ID 
          ORDER BY EVENT_TIMESTAMP 
          ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING))
    THEN 1 ELSE 0 END ISCONFIRMATION,
FIRST_VALUE (DEVICE.WEB_INFO.HOSTNAME IGNORE NULLS
  ) OVER (
    PARTITION BY GA_SESSION_ID
    ORDER BY EVENT_TIMESTAMP
    ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING
  ) DOMAIN,
  LOWER (FIRST_VALUE(TRAFFICSOURCE.CAMPAIGN IGNORE NULLS
    ) OVER (
      PARTITION BY GA_SESSION_ID 
      ORDER BY EVENT_TIMESTAMP 
      ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING
  )) TRAFFIC_CAMPAIGN_FIRST,
  page.page_location,
  page.page_path
FROM `koreabeta.LR_testing.ga4_flat_events` YETI
  LEFT JOIN `koreabeta.GIMLI.PALANTIR` PAL1
    ON USER_PSEUDO_ID = PAL1.USER_ID
  LEFT JOIN `koreabeta.GIMLI.PALANTIR` PAL2
    ON GA_SESSION_ID = PAL2.SESSION_ID
WHERE PAL1.USER_ID IS NULL 
  AND PAL2.SESSION_ID IS NULL 
  AND YETI.EVENT_DATE = "2026-01-06"  
  AND TRAFFIC_TYPE IS NULL  
  AND DEVICE.WEB_INFO.HOSTNAME IN ('abcam.com','www.abcam.com','www.abcam.cn','abcam.cn','www.abcam.co.jp','abcam.co.jp')  
  )
SELECT page_location,page_path, 
CASE WHEN PAGE_PATH LIKE '%/products/%' AND REGEXP_CONTAINS(LOWER(PAGE_PATH), r'ab[0-9]{1,6}') THEN 1 END,
COUNT(GA_SESSION_ID)
FROM CTE
WHERE COUNTRY = 'China' AND ISPDPQV = 0 AND PAGE_LOCATION LIKE '%product%'
GROUP BY 1,2
order by COUNT(GA_SESSION_ID) desc
