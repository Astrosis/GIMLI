  MAX(ISSEARCHWITHRESULTS) AS SEARCHWITHRESULTSSESSION,
  MAX(ISSEARCHWITHRESULTS * ADJUSTMENT_RATES) AS ADJUSTEDSEARCHWITHRESULTSSESSION,
  MAX(ISSEARCHWITHRESULTSTOPDP) AS SEARCHWITHRESULTSTOPDPSESSION,
  MAX(ISSEARCHWITHRESULTSTOPDP * ADJUSTMENT_RATES) AS ADJUSTEDSEARCHWITHRESULTSTOPDPSESSION,
  MAX(ISNEWVISITOR) AS ISNEWVISITOR,
  MAX(ISNEWVISITOR * ADJUSTMENT_RATES) AS ADJUSTEDISNEWVISITOR,
  MAX(ISBOUNCESESSION) AS ISBOUNCESESSION,
  MAX(ISBOUNCESESSION * ADJUSTMENT_RATES) AS ADJUSTEDISBOUNCESESSION,
  MAX(ISBASKET) AS ISBASKET,
  MAX(ISBASKET * ADJUSTMENT_RATES) AS ADJUSTEDISBASKET,
  MAX(ISCONFIRMATION) AS ISCONFIRMATION,
  MAX(ISCONFIRMATION * ADJUSTMENT_RATES) AS ADJUSTEDISCONFIRMATION,
  MAX (SESSION_DURATION) AS SESSION_DURATION

FROM CLEANED_ATTRIBUTION
GROUP BY
GA_SESSION_ID,
EVENT_DATE,
COUNTRY,
CITY,
SALESREGION,
SESSION_SOURCE,
SESSION_MEDIUM,
SESSION_CAMPAIGN,
DOMAIN,
LANDING_PAGE,
LANDING_PAGE_TYPE,
ISYETI2
)
SELECT 
  EVENT_DATE, 
  COUNTRY `Country`,
  CITY `City`,
  SALESREGION `Sales Region`,
  SESSION_SOURCE `Session Source`,
  SESSION_MEDIUM `Session Medium`,
  SESSION_CAMPAIGN `Session Campaign`,
  LANDING_PAGE `Session Landing Page`,
  LANDING_PAGE_TYPE `Session Landing Page Type`,
  ISYETI2 `Is Yeti2`,
  DOMAIN `Domain`,
  SUM (ISSESSION) `Number of Sessions`,
  SUM (ADJUSTEDSESSION) `Adjusted Number of Sessions`,
  SUM (ISPDP) `Number of PDP Sessions`, 
  SUM (ADJUSTEDPDPSESSION) `Adjusted Number of PDP Sessions`,
  SUM (ISPDPQV) `Number of PDPQV Sessions`, 
  SUM (ADJUSTEDPDPQVSESSION) `Adjusted Number of PDPQV Sessions`,
  SUM (SEARCHZERORESULTSSESSION) `Number of Zero-Search-Results Sessions`,
  SUM (ADJUSTEDSEARCHZERORESULTSSESSION) `Adjusted Number of Zero-Search-Results Sessions`,
  SUM (SEARCHWITHRESULTSSESSION) `Number of Search-with-Results Sessions`,
  SUM (ADJUSTEDSEARCHWITHRESULTSSESSION) `Adjusted Number of Search-with-Results Sessions`,
  SUM (SEARCHWITHRESULTSTOPDPSESSION) `Number of Search-with-Results to PDP Sessions`,
  SUM (ADJUSTEDSEARCHWITHRESULTSTOPDPSESSION) `Adjusted Number of Search-with-Results to PDP Sessions`,
  SUM(ISNEWVISITOR) `Number of New Visitors`,
  SUM (ADJUSTEDISNEWVISITOR) `Adjusted Number of New Visitors`,
  SUM(ISBOUNCESESSION)`Number of Bounce Sessions`,
  SUM (ADJUSTEDISBOUNCESESSION) `Adjusted Number of Bounce Sessions`,
  SUM(ISBASKET) `Number of Basket Sessions`,
  SUM (ADJUSTEDISBASKET) `Adjusted Number of Basket Sessions`,
  SUM(ISCONFIRMATION) `Number of Order Confirmation Sessions`,
  SUM (ADJUSTEDISCONFIRMATION) `Adjusted Number of Order Confirmation Sessions`,
  SUM (SESSION_DURATION) `Session Duration in Seconds`,
  'GA4-YETI' `Data Source`
FROM ADJUSTED
GROUP BY 
EVENT_DATE,  
COUNTRY,
CITY,
SALESREGION,
SESSION_SOURCE,
SESSION_MEDIUM,
SESSION_CAMPAIGN,
DOMAIN,
ISYETI2,
LANDING_PAGE,
LANDING_PAGE_TYPE
